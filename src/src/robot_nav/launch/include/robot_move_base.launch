<launch>
	<node pkg="move_base" type="move_base" respawn="true" name="move_base" output="screen" clear_params="true">
		<param name="base_global_planner" value="global_planner/GlobalPlanner"/>
		<param name="base_local_planner" value="teb_local_planner/TebLocalPlannerROS" />
		<rosparam file="$(find robot_nav)/config/common/move_base_params.yaml" command="load" />
		<rosparam file="$(find robot_nav)/config/common/local_costmap_params.yaml" command="load" />
		<rosparam file="$(find robot_nav)/config/common/global_costmap_params.yaml" command="load" />
		<rosparam file="$(find robot_nav)/config/common/base_global_planner_params.yaml" command="load" />
		<rosparam file="$(find robot_nav)/config/robot_fwd/costmap_common_params.yaml" command="load" ns="global_costmap" />
		<rosparam file="$(find robot_nav)/config/robot_fwd/costmap_common_params.yaml" command="load" ns="local_costmap" />
		<rosparam file="$(find robot_nav)/config/robot_fwd/teb_local_planner_params.yaml" command="load" />
	</node>
</launch>
