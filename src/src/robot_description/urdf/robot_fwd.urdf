<?xml version="1.0"?>
<robot name="robot">

    <link name="base_footprint"/>

    <link name="base_link">
        <visual>
            <geometry>
                <box size="0.23 0.23 0.01" /> </geometry>
            <material name="blue">
                <color rgba="0 0 0.8 1"/>
            </material>
        </visual>
    </link>

    <link name="layer_2_link">
        <visual>
            <geometry>
                <box size="0.23 0.23 0.005" />
            </geometry>
            <material name="white">
                <color rgba="1 1 1 0.6"/>
            </material>
        </visual>
    </link>

    <link name="imu_link">
        <visual>
            <geometry>
                <box size="0.02 0.015 0.005" /> </geometry>
            <material name="black">
                <color rgba="0 0 0 1"/>
            </material>
        </visual>
    </link>

    <link name="wheel_fl" />
    <link name="wheel_fr" />
    <link name="wheel_rl" />
    <link name="wheel_rr" />

    <link name="laser_link"/>

    <joint name="baselink2footprint" type="fixed">
        <origin xyz="0 0 0.065" rpy="0 0 0"/>
        <parent link="base_footprint" />
        <child  link="base_link" />
    </joint>

    <joint name="layer2_to_base" type="fixed">
        <origin xyz="0 0 0.1" rpy="0 0 0"/>
        <parent link="base_link" />
        <child  link="layer_2_link" />
    </joint>

    <joint name="imu_to_base" type="fixed">
        <origin xyz="0 0.09 0.11" rpy="0 0 0"/>
        <parent link="base_link" />
        <child  link="imu_link" />
    </joint>

    <joint name="wheel_fl_joint" type="continuous">
        <origin xyz="0.115 0.115 0" rpy="1.5707 0 0"/>
        <parent link="base_link" />
        <child  link="wheel_fl" />
        <axis xyz="0 0 1"/>
    </joint>

    <joint name="wheel_fr_joint" type="continuous">
        <origin xyz="0.115 -0.115 0" rpy="1.5707 0 0"/>
        <parent link="base_link" />
        <child  link="wheel_fr" />
        <axis xyz="0 0 1"/>
    </joint>

    <joint name="wheel_rl_joint" type="continuous">
        <origin xyz="-0.115 0.115 0" rpy="1.5707 0 0"/>
        <parent link="base_link" />
        <child  link="wheel_rl" />
        <axis xyz="0 0 1"/>
    </joint>

    <joint name="wheel_rr_joint" type="continuous">
        <origin xyz="-0.115 -0.115 0" rpy="1.5707 0 0"/>
        <parent link="base_link" />
        <child  link="wheel_rr" />
        <axis xyz="0 0 1"/>
    </joint>

    <joint name="laser2layer2" type="fixed">
        <origin xyz="0 0 0.05" rpy="0 0 0"/>
        <parent link="layer_2_link" />
        <child  link="laser_link" />
    </joint>

</robot>