<launch>
    <arg name="serial_port" default="/dev/robot_base"/>
    <arg name="baud_rate"   default="115200"/>

    <node pkg="rosserial_python" type="serial_node.py" name="serial_node" output="screen">
        <param name="port" value="$(arg serial_port)"/>
        <param name="baud" value="$(arg baud_rate)"/>
    </node>

    <node pkg="robot_robot" type="odom_to_tf.py" name="odom_tf_broadcaster" output="screen" />

    <include file="$(find robot_description)/launch/model.launch">
        <arg name="robot_type" value="robot_fwd"/>
    </include>

</launch>
