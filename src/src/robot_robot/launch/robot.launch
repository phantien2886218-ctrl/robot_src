<launch>
    <arg name="serial_port" default="/dev/robot_base"/>
    <arg name="baud_rate"   default="115200"/>

    <node pkg="rosserial_python" type="serial_node.py" name="rosserial_base" output="screen">
        <param name="port" value="$(arg serial_port)"/>
        <param name="baud" value="$(arg baud_rate)"/>
    </node>

    </launch>